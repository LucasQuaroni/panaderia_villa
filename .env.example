# Copia a .env.local y rellena desde Supabase → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

# Project URL (misma página, arriba: "Project URL")
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave para el navegador / SSR con RLS (nombre en código: "anon"):
# - UI nueva: usa la "Publishable key" (empieza por sb_publishable_...)
# - O pestaña "Legacy anon, service_role API keys" → copia "anon" "public"
# NUNCA pongas la "Secret key" (sb_secret_...) en variables NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
